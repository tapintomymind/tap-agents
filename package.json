{
  "name": "@tapintomymind/tap-agents",
  "version": "0.8.3",
  "description": "TapAgents — an opinionated AI product team for Claude Code. Curated agents, commands, protocols, and templates that scaffold a startup's worth of product roles (Strategist, Architect, Designer, Critic, Quality Engineer, Ops/Security) into any repo. Distributed via Claude Code marketplace and npm.",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./manifest.json": "./dist/manifest.json",
    "./agents/*": "./agents/*",
    "./commands/*": "./commands/*",
    "./protocols/*": "./protocols/*",
    "./templates/*": "./templates/*",
    "./hooks/*": "./hooks/*",
    "./playbooks/*": "./playbooks/*",
    "./memory/*": "./memory/*",
    "./docs/*": "./docs/*",
    "./settings.json": "./settings.json",
    "./.claude-plugin/*": "./.claude-plugin/*"
  },
  "files": [
    "dist",
    "agents",
    "commands",
    "protocols",
    "templates",
    "hooks",
    "scripts",
    "playbooks",
    "memory",
    "docs",
    ".claude-plugin",
    "AGENTS.md",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "settings.json"
  ],
  "scripts": {
    "build": "tsx scripts/build-src/build.ts",
    "verify": "tsx scripts/build-src/verify.ts",
    "prepublishOnly": "npm run build && npm run verify"
  },
  "keywords": [
    "claude-code",
    "claude",
    "ai-agents",
    "agent-framework",
    "product-team",
    "ai-engineering",
    "tapagents",
    "tapintomymind",
    "claude-plugin",
    "marketplace"
  ],
  "engines": {
    "node": ">=18.18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tapintomymind/tap-agents.git"
  },
  "homepage": "https://github.com/tapintomymind/tap-agents",
  "bugs": {
    "url": "https://github.com/tapintomymind/tap-agents/issues"
  },
  "author": "Tap Desai <tap@tapintomymind.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
