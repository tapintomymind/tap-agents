{
  "name": "@tapintomymind/tap-agents",
  "version": "0.35.1",
  "description": "TapAgents — an opinionated AI product team for Claude Code. Curated agents, commands, protocols, and templates that scaffold a startup's worth of product roles (Strategist, Architect, Designer, Critic, Quality Engineer, Ops/Security) into any repo. Distributed via Claude Code marketplace and npm.",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./manifest.json": "./dist/manifest.json",
    "./agents/*": "./agents/*",
    "./commands/*": "./commands/*",
    "./protocols/*": "./protocols/*",
    "./templates/*": "./templates/*",
    "./hooks/*": "./hooks/*",
    "./.claude-plugin/*": "./.claude-plugin/*"
  },
  "files": [
    "dist",
    "agents",
    "cli",
    "commands",
    "protocols",
    "templates",
    "hooks",
    ".claude-plugin",
    "AGENTS.md",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "playbooks",
    "memory",
    "docs",
    "runtime-adapters",
    "settings.json",
    "!docs/specs",
    "!**/__pycache__",
    "!**/*.pyc",
    "!**/*.pyo"
  ],
  "scripts": {
    "build": "tsx scripts/build-src/build.ts",
    "verify": "tsx scripts/build-src/verify.ts",
    "sync": "tsx scripts/sync-src/sync.ts --dry-run",
    "sync:dry-run": "tsx scripts/sync-src/sync.ts --dry-run",
    "sync:apply": "tsx scripts/sync-src/sync.ts --apply",
    "verify-sync": "tsx scripts/sync-src/verify-sync.ts",
    "verify-genericize": "tsx scripts/sync-src/verify-genericize.ts",
    "test:changelog-format": "tsx scripts/test-changelog-format.ts",
    "test:cli": "node --test scripts/test-tapagents-cli.mjs",
    "audit:version-parity": "tsx scripts/version-parity-audit.ts",
    "prepublishOnly": "npm run build && npm run verify"
  },
  "keywords": [
    "claude-code",
    "claude",
    "ai-agents",
    "agent-framework",
    "product-team",
    "ai-engineering",
    "tapagents",
    "tapintomymind",
    "claude-plugin",
    "marketplace"
  ],
  "engines": {
    "node": ">=18.18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tapintomymind/tap-agents.git"
  },
  "homepage": "https://github.com/tapintomymind/tap-agents",
  "bugs": {
    "url": "https://github.com/tapintomymind/tap-agents/issues"
  },
  "author": "Tap Desai <tap@tapintomymind.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "json5": "^2.2.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0"
  },
  "bin": {
    "tapagents": "./cli/tapagents.mjs"
  }
}
