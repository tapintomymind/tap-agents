# ────────────────────────────────────────────────────────────
# Claude Team — Public / Private split
# Public layer: agent prompts, protocols, templates, examples
# Private layer: your real memory and workspace
# ────────────────────────────────────────────────────────────

# Private memory — keep examples/changelog public
memory/*.md
!memory/README.md
!memory/agent-changelog.md
!memory/incidents.md
!memory/backlog.md
!memory/framework-metrics-rollup-*.md
memory/_examples/
!memory/_examples/

# Framework metrics raw log — gitignored per protocols/framework-metrics.md §2.
# Events may include project context; raw log is local-only. Aggregated
# rollups (memory/framework-metrics-rollup-*.md) ARE committed —
# re-included via the !pattern in the section above.
memory/*.jsonl

# Actually, let _examples ship and only ignore real memory files:
# (rules above ignore *.md files; the !memory/_examples/ re-includes the dir)

# Dream-pass candidate + archive stores — transient, regenerated per pass (BL-031).
# memory.next/ is the proposed-output candidate created by /consolidate-memory --dream-pass;
#   deleted on user accept (atomic mv to memory/) or discard (rm -rf).
# memory.prev.<ISO-ts>/ is the post-accept archive (90-day retention per protocols/dream-pass.md §3).
# Agents NEVER read these directories — runtime reads ${MEMORY_ROOT:-memory}/ exclusively;
# setting MEMORY_ROOT=memory.next/ is forbidden by protocols/dream-pass.md §2.
memory.next/
memory.prev.*/

# Private workspace — keep _examples/, _registry.md, _global structure (templates), and .gitkeep
workspace/*
!workspace/_examples/
!workspace/_registry.md
!workspace/_global/
!workspace/.gitkeep
workspace/_global/*
!workspace/_global/portfolio.json
!workspace/_global/setup_state.json
!workspace/_global/backlog.json
!workspace/_global/.gitkeep

# Private playbooks
playbooks/_private/

# Private agent overrides (future fork mechanism)
agents/_private/

# Standard ignores
.DS_Store
*.local.json
.env
.env.*
!.env.example

# Editor / OS noise
*.swp
*.swo
*~
.vscode/
.idea/

# Build artifacts
node_modules/
__pycache__/
*.pyc

# Generated by scripts/build-src/build.ts — npm-package surface
# Committed via the publish workflow on tag push; never authored by hand.
dist/

# npm internals
.npm
npm-debug.log*
*.tgz
package-lock.json.bak
